# Copy this file to .env and fill in your values.
# Do not commit .env – it is in .gitignore.

# PostgreSQL connection (Supabase, Neon, or local).
# For Supabase: Project Settings → Database → Connection string (URI).
# If the password contains special characters (e.g. ], [, {, }), URL-encode them.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_HOST:5432/postgres

# Secret used to protect POST /api/refresh (e.g. from cron-job.org).
REFRESH_SECRET=your-long-random-refresh-secret
